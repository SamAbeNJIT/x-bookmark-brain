# --- X (Twitter) session credentials for the backfill ---
# From your logged-in browser session (DevTools > Application > Cookies on x.com).
X_AUTH_TOKEN=
X_CSRF_TOKEN=
# The hash in the /i/api/graphql/<THIS>/Bookmarks request URL (DevTools > Network tab).
X_BOOKMARKS_QUERY_ID=

# --- AWS / Amazon Bedrock (embeddings, labeling, answers) ---
# Requires Bedrock model access for Claude + Titan in this region.
# AWS credentials are read from the standard chain (~/.aws/credentials, env vars, SSO, IAM
# role) — you usually do NOT need keys here. Uncomment only if not using ~/.aws:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Bedrock model IDs. Current Claude models need the cross-region inference profile form
# (us.anthropic.…), not the bare anthropic.… id.
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_LABELING_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0   # cheap/fast bulk labeling
BEDROCK_REASONING_MODEL=us.anthropic.claude-sonnet-4-6               # taxonomy + answers
