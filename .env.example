# --- X (Twitter) session credentials for the one-time backfill ---
# Pulled from your logged-in browser session (DevTools > Application > Cookies on x.com).
# These authenticate the ingestion against X's internal bookmarks endpoint.
X_AUTH_TOKEN=
X_CSRF_TOKEN=

# --- AWS / Amazon Bedrock (AI: categorization, embeddings, answers) ---
# Requires Bedrock model access enabled for Claude + Titan embeddings in this region.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Model selection (Bedrock model IDs)
BEDROCK_LABELING_MODEL=          # cheap/fast Claude model for bulk per-post labeling
BEDROCK_REASONING_MODEL=         # stronger Claude model for taxonomy derivation + answers
BEDROCK_EMBEDDING_MODEL=         # e.g. Amazon Titan Text Embeddings
