# --- Storage: Postgres + pgvector (Neon) ---
# A Postgres database with the pgvector extension. Neon (neon.com) is the easy path: create a
# project (AWS region), copy the connection string here. Free tier (0.5 GB) fits a ~16k-bookmark
# corpus. The schema is multi-tenant with Row-Level Security; locally you are the single tenant.
#
# DATABASE_URL = the owner role (DDL / migrations / admin).
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require
# APP_DATABASE_URL = the restricted role the web app connects as so RLS is ENFORCED (the Neon
# owner has BYPASSRLS and would bypass it). Create it once with:
#     python scripts/setup_app_role.py     # creates role xbb_app + writes APP_DATABASE_URL here
# If unset, the app falls back to DATABASE_URL (works, but RLS is not enforced).
APP_DATABASE_URL=postgresql://xbb_app:PASSWORD@HOST.neon.tech/neondb?sslmode=require
# XBB_TENANT_ID=00000000-0000-0000-0000-000000000001   # override the default single-user tenant

# --- Auth (magic-link login) ---
# Secret for signing magic-link + session tokens. Generate one: python -c "import secrets;print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me
# REQUIRE_AUTH=true   # gate the app behind login (hosted/multi-user). Unset locally → no session
#                     # falls back to the single default tenant (your existing data).

# --- X OAuth 2.0 (sanctioned bookmarks API) ---
# Register a developer app at developer.x.com → Native App (public client, PKCE — no secret),
# permission Read, callback http://127.0.0.1:8000/oauth/callback. Copy its OAuth 2.0 Client ID.
# Then run the app and click "Connect X" to authorize (tokens are stored locally, auto-refreshed).
X_CLIENT_ID=
X_REDIRECT_URI=http://127.0.0.1:8000/oauth/callback

# --- AWS / Amazon Bedrock (embeddings, labeling, answers) ---
# Requires Bedrock model access for Claude + Titan in this region.
# AWS credentials are read from the standard chain (~/.aws/credentials, env vars, SSO, IAM
# role) — you usually do NOT need keys here. Uncomment only if not using ~/.aws:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Bedrock model IDs. Current Claude models need the cross-region inference profile form
# (us.anthropic.…), not the bare anthropic.… id.
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_LABELING_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0   # cheap/fast bulk labeling
BEDROCK_REASONING_MODEL=us.anthropic.claude-sonnet-4-6               # taxonomy + answers

# --- AWS hardening (optional; unset → safe local fallbacks) ---
# KMS key that encrypts users' X OAuth tokens at rest. Unset → tokens stored plaintext (local).
# KMS_KEY_ID=alias/xbb-tokens
# SES verified sender for magic-link emails. Unset → the link is logged to the console (local).
# Note: SES starts in sandbox (only verified recipients) — request production access for real users.
# SES_SENDER=you@yourdomain.com

# --- Billing (Stripe) + cost caps ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID=price_...           # the recurring price for the Pro plan
# STRIPE_WEBHOOK_SECRET=whsec_...     # from `stripe listen` (local) or the dashboard webhook
# MONTHLY_QUOTA_USD=                  # default per-tenant Bedrock spend cap; unset = unlimited
